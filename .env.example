# ==============================================================================
# PG Management System - Environment Configuration Template
# ==============================================================================
# This file serves as a template for your local .env file.
# Copy this file to .env and fill in the actual values.
#
# Usage:
#   cp .env.example .env
# ==============================================================================

# ------------------------------------------------------------------------------
# Server Configuration
# ------------------------------------------------------------------------------
# The port on which the Express server will run
PORT=5000

# Node environment (development, production, test)
NODE_ENV=development

# ------------------------------------------------------------------------------
# Database Configuration
# ------------------------------------------------------------------------------
# MongoDB connection string
# For local: mongodb://localhost:27017/pg-system
# For Atlas: mongodb+srv://<username>:<password>@cluster.mongodb.net/pgSystem
MONGO_URI=your_mongodb_connection_string_here

# ------------------------------------------------------------------------------
# Authentication & Security
# ------------------------------------------------------------------------------
# Secret key for signing JSON Web Tokens
# Suggested: Generate a strong random string (e.g., `openssl rand -base64 32`)
JWT_SECRET=your_jwt_secret_key_here

# ------------------------------------------------------------------------------
# Cloudinary Configuration (Media Storage)
# ------------------------------------------------------------------------------
# Cloudinary credentials for handling image uploads
CLOUDINARY_CLOUD_NAME=your_cloudinary_cloud_name
CLOUDINARY_API_KEY=your_cloudinary_api_key
CLOUDINARY_API_SECRET=your_cloudinary_api_secret

# ------------------------------------------------------------------------------
# Frontend Configuration (Optional)
# ------------------------------------------------------------------------------
# The URL of the frontend application (for CORS configuration)
# CLIENT_URL=http://localhost:3000